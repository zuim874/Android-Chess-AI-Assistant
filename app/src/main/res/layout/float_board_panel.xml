<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/llBoardPanel"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/float_window_bg"
    android:padding="8dp"
    android:gravity="center">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="模拟棋盘"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPanelSide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="执红"
            android:textColor="#FFCDD2"
            android:textSize="11sp"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnPanelClose"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:text="X"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:background="@android:color/transparent" />
    </LinearLayout>

    <!-- 棋盘视图 -->
    <com.chessautoplayer.view.ChessBoardView
        android:id="@+id/chessBoardView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp" />

    <!-- 颜色选择 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="选择："
            android:textColor="#B3E5FC"
            android:textSize="11sp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnColorRed"
            android:layout_width="36dp"
            android:layout_height="28dp"
            android:text="红"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:backgroundTint="#D32F2F"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnColorBlack"
            android:layout_width="36dp"
            android:layout_height="28dp"
            android:text="黑"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:backgroundTint="#616161"
            android:layout_marginEnd="8dp" />
    </LinearLayout>

    <!-- 棋子类型选择 -->
    <LinearLayout
        android:id="@+id/llPieceSelector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="4dp">

        <Button
            android:id="@+id/btnPieceKing"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:text="帅"
            android:textSize="10sp"
            android:padding="1dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnPieceAdvisor"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:text="仕"
            android:textSize="10sp"
            android:padding="1dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnPieceElephant"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:text="相"
            android:textSize="10sp"
            android:padding="1dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnPieceHorse"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:text="馬"
            android:textSize="10sp"
            android:padding="1dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnPieceRook"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:text="車"
            android:textSize="10sp"
            android:padding="1dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnPieceCannon"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:text="炮"
            android:textSize="10sp"
            android:padding="1dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnPiecePawn"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:text="兵"
            android:textSize="10sp"
            android:padding="1dp"
            android:minWidth="0dp"
            android:minHeight="0dp" />
    </LinearLayout>

    <!-- 复盘代理状态栏 -->
    <TextView
        android:id="@+id/tvReviewAgentStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="4dp"
        android:layout_marginBottom="4dp"
        android:background="#1565C0"
        android:visibility="gone" />

    <!-- AI建议显示 -->
    <TextView
        android:id="@+id/tvAiHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="点击棋子类型后点击棋盘放置"
        android:textColor="#B3E5FC"
        android:textSize="10sp"
        android:gravity="center"
        android:layout_marginBottom="4dp"
        android:minHeight="24dp" />

    <!-- AI指导按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="4dp">

        <Button
            android:id="@+id/btnAiRed"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:text="AI帮红方"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:backgroundTint="#D32F2F"
            android:layout_marginEnd="4dp" />

        <ToggleButton
            android:id="@+id/btnReviewAgent"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:textOn="复盘代理中"
            android:textOff="复盘代理"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:backgroundTint="#7B1FA2"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnAiBlack"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:text="AI帮黑方"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:backgroundTint="#424242" />
    </LinearLayout>

    <!-- 动画开关 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="训练动画"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <ToggleButton
            android:id="@+id/tbShowAnimation"
            android:layout_width="60dp"
            android:layout_height="28dp"
            android:textOn="开"
            android:textOff="关"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2196F3"
            android:checked="false" />
    </LinearLayout>

    <!-- 随机探索率 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="随机探索率"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnExploreMinus"
            android:layout_width="34dp"
            android:layout_height="28dp"
            android:text="-"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:backgroundTint="#616161" />

        <TextView
            android:id="@+id/tvExploreRate"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="12%"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center" />

        <Button
            android:id="@+id/btnExplorePlus"
            android:layout_width="34dp"
            android:layout_height="28dp"
            android:text="+"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:backgroundTint="#616161" />
    </LinearLayout>

    <!-- 并发数选择 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="并发局数"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnConcurrentMinus"
            android:layout_width="34dp"
            android:layout_height="28dp"
            android:text="-"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:backgroundTint="#616161" />

        <TextView
            android:id="@+id/tvConcurrentValue"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="1"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="center" />

        <Button
            android:id="@+id/btnConcurrentPlus"
            android:layout_width="34dp"
            android:layout_height="28dp"
            android:text="+"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:backgroundTint="#616161" />
    </LinearLayout>

    <!-- 训练控制 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="4dp">

        <Button
            android:id="@+id/btnTrain"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:text="开始训练"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:backgroundTint="#4CAF50"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnStopTrain"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:text="停止训练"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:backgroundTint="#F44336"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnViewBook"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:text="查看棋谱"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:backgroundTint="#FF9800" />
    </LinearLayout>

    <!-- 训练进度 -->
    <TextView
        android:id="@+id/tvTrainProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#81C784"
        android:textSize="9sp"
        android:gravity="center"
        android:layout_marginBottom="4dp"
        android:minHeight="16dp" />

    <!-- 操作按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnResetBoard"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:text="重置"
            android:textSize="10sp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnUndoMove"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:text="悔一步"
            android:textSize="10sp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnClearBoard"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:text="清空"
            android:textSize="10sp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnFlipBoard"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:text="翻转"
            android:textSize="10sp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp" />
    </LinearLayout>

</LinearLayout>